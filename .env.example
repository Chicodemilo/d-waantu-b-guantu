# Database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=23847
MYSQL_DATABASE=local_agent_tracker
MYSQL_USER=lat_user
MYSQL_PASSWORD=lat_dev_password
MYSQL_ROOT_PASSWORD=lat_root_password

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
ADMIN_API_KEY=lat-admin-CHANGE-ME-TO-RANDOM-64-CHAR-HEX

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api
VITE_POLL_ACTIVE_MS=1000

# phpMyAdmin
PMA_PORT=8080

# Jira (optional — leave blank to disable /api/jira/* endpoints)
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_CACHE_TTL_SECONDS=60

# Session write-up summarizer (DWBG-014). The model that generates the
# human-readable session wrap-up narrative on close (gated per project by
# force_session_writeup, default ON). Generation is best-effort: if the chosen
# backend is unavailable, closes still succeed with the deterministic summary and
# no narrative.
#
# DWBG-017: the inference backend is pluggable via DWB_SUMMARIZER_PROVIDER.
#   ollama    (DEFAULT) — local Ollama daemon, no API key. Privacy default: the
#                         work record's git diff never leaves the machine.
#   anthropic           — the Claude API. Ships the diff to a remote API; needs
#                         ANTHROPIC_API_KEY. Leave the key blank to disable.
#   mlx                 — future on-device Apple-silicon backend; STUB (no-op today).
# An unknown value falls back to the default (ollama).
DWB_SUMMARIZER_PROVIDER=ollama

# DWB_SUMMARIZER_MODEL is shared by all providers but the sensible default differs
# per backend: a code-capable LOCAL model for Ollama (qwen2.5-coder), and
# claude-sonnet-4-6 for Anthropic. Set it to match the provider you select.
DWB_SUMMARIZER_MODEL=qwen2.5-coder

# Ollama daemon base URL (used when DWB_SUMMARIZER_PROVIDER=ollama).
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic API key (used only when DWB_SUMMARIZER_PROVIDER=anthropic). Blank
# disables the Anthropic backend; a close then proceeds without an LLM narrative.
ANTHROPIC_API_KEY=
